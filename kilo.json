{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "openai/gpt-4o",
  "small_model": "openai/gpt-4o-mini",
  "default_agent": "medical-dev",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "time": {
      "type": "remote",
      "url": "https://time.mcp.api.anthropic.com"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp", "serve"]
    },
    "github": {
      "type": "remote",
      "url": "https://api.github.com/mcp"
    },
    "gitmcp": {
      "type": "remote",
      "url": "https://gitmcp.io"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com"
    }
  }
}